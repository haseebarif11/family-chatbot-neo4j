<!-- =============================================================== -->
<!--  Gender checks                                                  -->
<!-- =============================================================== -->

<category><pattern>IS * MALE</pattern>
  <template><set name="gender_check">male</set><set name="p1"><star/></set>CHECK_GENDER</template></category>
<category><pattern>IS * FEMALE</pattern>
  <template><set name="gender_check">female</set><set name="p1"><star/></set>CHECK_GENDER</template></category>
<category><pattern>IS * A MALE</pattern>
  <template><set name="gender_check">male</set><set name="p1"><star/></set>CHECK_GENDER</template></category>
<category><pattern>IS * A FEMALE</pattern>
  <template><set name="gender_check">female</set><set name="p1"><star/></set>CHECK_GENDER</template></category>
<category><pattern>* MALE TRUE OR FALSE</pattern>
  <template><set name="gender_check">male</set><set name="p1"><star/></set>CHECK_GENDER</template></category>
<category><pattern>* FEMALE TRUE OR FALSE</pattern>
  <template><set name="gender_check">female</set><set name="p1"><star/></set>CHECK_GENDER</template></category>

<!-- =============================================================== -->
<!--  Greetings & Help                                               -->
<!-- =============================================================== -->

<category>
  <pattern>HI</pattern>
  <template>Hi there! Add family data or ask about relationships. Type HELP for examples.</template>
</category>

<category>
  <pattern>HELLO</pattern>
  <template>Hello! Add members with commands like ADD MALE PERSON Ali, or ask who is the father of Ali.</template>
</category>

<category>
  <pattern>HEY</pattern>
  <template>Hey! Add family facts or ask relationship questions.</template>
</category>

<category>
  <pattern>HELP</pattern>
  <template>
Add data:
- ADD MALE PERSON Ali
- ADD PARENT Haider OF Ali
- Ali is male
- Haider is the father of Ali

Ask questions:
- Who is the father of Ali?
- How old is Haider?
- Is Ali male?
  </template>
</category>

<!-- Additional natural-language query forms -->
<category><pattern>*'S FATHER</pattern>
  <template><set name="rel">father</set><set name="p1"><star/></set><get name="p2"/></template></category>
<category><pattern>*'S MOTHER</pattern>
  <template><set name="rel">mother</set><set name="p1"><star/></set><get name="p2"/></template></category>
<category><pattern>*'S PARENTS</pattern>
  <template><set name="rel">parents</set><set name="p1"><star/></set><get name="p2"/></template></category>
<category><pattern>*'S CHILDREN</pattern>
  <template><set name="rel">children</set><set name="p1"><star/></set><get name="p2"/></template></category>
<category><pattern>*'S SIBLINGS</pattern>
  <template><set name="rel">siblings</set><set name="p1"><star/></set><get name="p2"/></template></category>
<category><pattern>*'S SPOUSE</pattern>
  <template><set name="rel">spouse</set><set name="p1"><star/></set><get name="p2"/></template></category>
<category><pattern>*'S AGE</pattern>
  <template><set name="rel">age</set><set name="p1"><star/></set><get name="p2"/></template></category>

<category><pattern>WHAT IS THE RELATIONSHIP BETWEEN * AND *</pattern>
  <template><set name="rel">discover</set><set name="p1"><star/></set><set name="p2"><star index="2"/></set>DISCOVER_RELATIONSHIP</template></category>
<category><pattern>WHO IS OLDER * OR *</pattern>
  <template><set name="rel">compare_age</set><set name="p1"><star/></set><set name="p2"><star index="2"/></set><set name="cmp">older</set>COMPARE_AGE</template></category>
<category><pattern>WHO IS OLDER, * OR *</pattern>
  <template><set name="rel">compare_age</set><set name="p1"><star/></set><set name="p2"><star index="2"/></set><set name="cmp">older</set>COMPARE_AGE</template></category>
<category><pattern>IS * OLDER THAN *</pattern>
  <template><set name="rel">compare_age</set><set name="p1"><star/></set><set name="p2"><star index="2"/></set><set name="cmp">older</set>COMPARE_AGE</template></category>
<category><pattern>IS * YOUNGER THAN *</pattern>
  <template><set name="rel">compare_age</set><set name="p1"><star/></set><set name="p2"><star index="2"/></set><set name="cmp">younger</set>COMPARE_AGE</template></category>
<category><pattern>ALL FAMILY MEMBERS</pattern>
  <template><set name="rel">members</set><set name="p1"></set>MEMBERS_LIST</template></category>
<category><pattern>LIST ALL FAMILY MEMBERS</pattern>
  <template><set name="rel">members</set><set name="p1"></set>MEMBERS_LIST</template></category>
<category><pattern>LIST FAMILY MEMBERS</pattern>
  <template><set name="rel">members</set><set name="p1"></set>MEMBERS_LIST</template></category>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- Inference & Knowledge-Discovery patterns                       -->
<!-- ═══════════════════════════════════════════════════════════════ -->

<!-- Feature 1: Mutual Connections -->
<category>
  <pattern>WHAT DO * AND * HAVE IN COMMON</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>MUTUAL_CONNECTIONS</template>
</category>
<category>
  <pattern>WHAT CONNECTS * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>MUTUAL_CONNECTIONS</template>
</category>
<category>
  <pattern>FIND MUTUAL CONNECTIONS BETWEEN * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>MUTUAL_CONNECTIONS</template>
</category>
<category>
  <pattern>COMMON ANCESTOR OF * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>MUTUAL_CONNECTIONS</template>
</category>

<!-- Feature 2: Hidden / Indirect Relationships -->
<category>
  <pattern>HOW IS * RELATED TO *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>HIDDEN_RELATIONSHIP</template>
</category>
<category>
  <pattern>WHAT IS THE HIDDEN RELATIONSHIP BETWEEN * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>HIDDEN_RELATIONSHIP</template>
</category>
<category>
  <pattern>EXPLAIN THE CONNECTION BETWEEN * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>HIDDEN_RELATIONSHIP</template>
</category>
<category>
  <pattern>FIND INDIRECT RELATIONSHIP BETWEEN * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>HIDDEN_RELATIONSHIP</template>
</category>

<!-- Feature 3: Age Similarity / Recommendations -->
<category>
  <pattern>WHO IS CLOSE IN AGE TO *</pattern>
  <template><set name="p1"><star/></set>AGE_SIMILARITY</template>
</category>
<category>
  <pattern>SUGGEST A COMPANION FOR *</pattern>
  <template><set name="p1"><star/></set>AGE_SIMILARITY</template>
</category>
<category>
  <pattern>WHO IS SIMILAR IN AGE TO *</pattern>
  <template><set name="p1"><star/></set>AGE_SIMILARITY</template>
</category>
<category>
  <pattern>PLAYDATE FOR *</pattern>
  <template><set name="p1"><star/></set>AGE_SIMILARITY</template>
</category>

<!-- Feature 4: Graph Analysis Report -->
<category>
  <pattern>TELL ME ABOUT THE FAMILY GRAPH</pattern>
  <template>GRAPH_REPORT</template>
</category>
<category>
  <pattern>ANALYSE THE FAMILY GRAPH</pattern>
  <template>GRAPH_REPORT</template>
</category>
<category>
  <pattern>ANALYZE THE FAMILY GRAPH</pattern>
  <template>GRAPH_REPORT</template>
</category>
<category>
  <pattern>WHO IS THE MOST CONNECTED PERSON</pattern>
  <template>GRAPH_REPORT</template>
</category>
<category>
  <pattern>FAMILY GRAPH REPORT</pattern>
  <template>GRAPH_REPORT</template>
</category>
<category>
  <pattern>GRAPH STRUCTURE</pattern>
  <template>GRAPH_REPORT</template>
</category>
<category>
  <pattern>GRAPH STATS</pattern>
  <template>GRAPH_REPORT</template>
</category>

<!-- Feature 5: Interactive Graph Visualization (PyVis) -->
<category>
  <pattern>SHOW FAMILY TREE</pattern>
  <template>VISUALIZE_FULL</template>
</category>
<category>
  <pattern>SHOW FULL GRAPH</pattern>
  <template>VISUALIZE_FULL</template>
</category>
<category>
  <pattern>VISUALIZE GRAPH</pattern>
  <template>VISUALIZE_FULL</template>
</category>
<category>
  <pattern>SHOW GRAPH</pattern>
  <template>VISUALIZE_FULL</template>
</category>
<category>
  <pattern>SHOW SUBGRAPH OF *</pattern>
  <template><set name="p1"><star/></set>VISUALIZE_SUBGRAPH</template>
</category>
<category>
  <pattern>SUBGRAPH FOR *</pattern>
  <template><set name="p1"><star/></set>VISUALIZE_SUBGRAPH</template>
</category>
<category>
  <pattern>SUBGRAPH OF *</pattern>
  <template><set name="p1"><star/></set>VISUALIZE_SUBGRAPH</template>
</category>
<category>
  <pattern>HIGHLIGHT PATH BETWEEN * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>VISUALIZE_HIGHLIGHT</template>
</category>
<category>
  <pattern>VISUALIZE PATH BETWEEN * AND *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>VISUALIZE_HIGHLIGHT</template>
</category>
<category>
  <pattern>SHOW PATH FROM * TO *</pattern>
  <template><set name="p1"><star/></set><set name="p2"><star index="2"/></set>VISUALIZE_HIGHLIGHT</template>
</category>

<!-- Feature 6: Hybrid Neo4j–Prolog Bridge -->
<category>
  <pattern>SYNC PROLOG BRIDGE</pattern>
  <template>PROLOG_SYNC</template>
</category>
<category>
  <pattern>RUN PROLOG INFERENCE</pattern>
  <template>PROLOG_SYNC</template>
</category>
<category>
  <pattern>IMPORT PROLOG INFERENCE</pattern>
  <template>PROLOG_SYNC</template>
</category>
<category>
  <pattern>EXPORT TO PROLOG AND SYNC</pattern>
  <template>PROLOG_SYNC</template>
</category>
<category>
  <pattern>PROLOG * OF *</pattern>
  <template><set name="rel"><star/></set><set name="p1"><star index="2"/></set>PROLOG_QUERY</template>
</category>
<category>
  <pattern>QUERY PROLOG * OF *</pattern>
  <template><set name="rel"><star/></set><set name="p1"><star index="2"/></set>PROLOG_QUERY</template>
</category>
<category>
  <pattern>ASK PROLOG * OF *</pattern>
  <template><set name="rel"><star/></set><set name="p1"><star index="2"/></set>PROLOG_QUERY</template>
</category>

<!-- Default fallback -->
<category>
  <pattern>*</pattern>
  <template>I only answer family questions. Try: "father of Ali" or type HELP.</template>
</category>

<!-- Data-entry and deletion patterns -->
<!-- =============================================================== -->
<!--  Structured data-entry commands                                 -->
<!-- =============================================================== -->

<category>
  <pattern>ADD MALE PERSON *</pattern>
  <template>
    <set name="fact_type">male</set>
    <set name="person1"><star/></set>
    DATA_ENTRY
  </template>
</category>

<category>
  <pattern>ADD MALE *</pattern>
  <template>
    <set name="fact_type">male</set>
    <set name="person1"><star/></set>
    DATA_ENTRY
  </template>
</category>

<category>
  <pattern>ADD FEMALE PERSON *</pattern>
  <template>
