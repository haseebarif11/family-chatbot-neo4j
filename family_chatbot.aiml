<category><pattern>WHO IS THE OLDEST</pattern>
  <template><set name="rel">oldest</set>OLDEST</template></category>
<category><pattern>OLDEST</pattern>
  <template><set name="rel">oldest</set>OLDEST</template></category>

<category><pattern>WHO IS THE OLDEST MALE</pattern>
  <template><set name="rel">oldest_male</set>OLDEST_MALE</template></category>
