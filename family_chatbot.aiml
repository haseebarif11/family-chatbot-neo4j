<?xml version="1.0" encoding="UTF-8"?>
<aiml version="1.0.1" encoding="UTF-8">

<!-- Query patterns -->
<!-- =============================================================== -->
<!--  Relationship questions: "WHO IS THE father OF Ali"            -->
<!-- =============================================================== -->

<category>
  <pattern>WHO ARE THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>WHO ARE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>WHO IS * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>WHO IS THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>CAN YOU TELL ME WHO IS * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>TELL ME THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>TELL ME * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>WHAT IS THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>WHAT IS * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>DO YOU KNOW THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

<category>
  <pattern>FIND THE * OF *</pattern>
  <template>
    <set name="rel"><star/></set>
    <set name="p1"><star index="2"/></set>
    <get name="p2"/> IS <get name="rel"/> OF <get name="p1"/>
  </template>
</category>

